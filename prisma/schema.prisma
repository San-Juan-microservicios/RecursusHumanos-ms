// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

enum EstadoAsistencia {
  PRESENTE
  AUSENTE
  TARDANZA
  PERMISO
  FERIADO
}

enum EstadoPlanilla {
  BORRADOR
  CERRADA
}

model Tipo {
  id          Int      @id @default(autoincrement())
  nombre      String   @unique
  descripcion String?
  isActive    Boolean  @default(true)

  empleado    Empleado[]
}


model Empleado {
  id           Int       @id @default(autoincrement())
  nombre       String
  apellido     String
  ci           String    @unique
  password     String
  rol          String
  sueldo       Float
  idTipo       Int       
  tipo         Tipo       @relation(fields: [idTipo], references: [id])
  fechaIngreso DateTime
  isActive     Boolean   @default(true)
  permisos     Permisos[] // Relación 1:N con Permiso

    asistencias  Asistencia[]       // 👈 agregar esta línea
    detalles     DetallePlanilla[]  // 👈 agregar esta línea
}

model Permisos {
  id Int @id @default(autoincrement())
  titulo String
  tipo String
  descripcion String
  fechaInicio DateTime @default(now())
  fechaFin DateTime?
  isActive Boolean @default(true)
  estadoPermiso String @default("CURSANDO")
  idEmpleado  Int
  empleado    Empleado  @relation(fields: [idEmpleado], references: [id])
}

model Asistencia {
  id          Int              @id @default(autoincrement())
  idEmpleado  Int
  fecha       DateTime         @default(now())
  estado      EstadoAsistencia
  observacion String?
  creadoEn    DateTime         @default(now())

  empleado    Empleado         @relation(fields: [idEmpleado], references: [id])

  // @@unique([idEmpleado, fecha])
}

model Planilla {
  id        Int              @id @default(autoincrement())
  mes       Int              // 1–12
  anio      Int
  estado    EstadoPlanilla   @default(BORRADOR)
  creadoEn  DateTime         @default(now())
  cerradoEn DateTime?

  detalles  DetallePlanilla[]

  @@unique([mes, anio])
}

model DetallePlanilla {
  id             Int      @id @default(autoincrement())
  idPlanilla     Int
  idEmpleado     Int
  salarioBase    Float
  diasTrabajados Int
  diasAusente    Int
  descuentos     Float
  totalAPagar    Float
  observacion    String?

  planilla       Planilla @relation(fields: [idPlanilla], references: [id])
  empleado       Empleado @relation(fields: [idEmpleado], references: [id])

  @@unique([idPlanilla, idEmpleado])
}